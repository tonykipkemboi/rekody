---
---

<section class="max-w-5xl mx-auto px-6 py-10">
  <h2 class="text-3xl font-bold text-center mb-3" style="color:#ffffff;">See how it works</h2>
  <p class="text-center mb-10" style="color:#a0a0b0;">From microphone to text at your cursor — the full pipeline in one diagram.</p>

  <!-- Terminal chrome wrapper -->
  <div class="rounded-2xl border border-[#2a3a5c] overflow-hidden shadow-2xl" style="background-color:#0a0f1e;">
    <!-- Window bar -->
    <div class="flex items-center gap-2 px-4 py-3 border-b border-[#2a3a5c]" style="background-color:#131c30;">
      <span class="w-3 h-3 rounded-full bg-[#ef4444]"></span>
      <span class="w-3 h-3 rounded-full bg-[#f59e0b]"></span>
      <span class="w-3 h-3 rounded-full bg-[#22c55e]"></span>
      <span class="ml-3 text-xs font-mono" style="color:#a0a0b0;">chamgei — how it works</span>
    </div>

    <!-- Diagram or placeholder -->
    <div class="p-6">
      <!-- If flow-diagram.png is present, show it; otherwise show the ASCII flow -->
      <noscript>
        <img src="/flow-diagram.png" alt="chamgei data flow diagram" class="w-full rounded-lg" />
      </noscript>
      <div id="demo-content">
        <!-- ASCII flow shown until real diagram is swapped in -->
        <div class="font-mono text-sm leading-loose overflow-x-auto" style="color:#e0e0e0;">
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-0 flex-wrap">
            <span class="px-3 py-1.5 rounded-lg border border-[#4a9eed]" style="background-color:#1e3a5f;color:#4a9eed;">Microphone</span>
            <span class="sm:px-2" style="color:#2a3a5c;">──⌥Space──▶</span>
            <span class="px-3 py-1.5 rounded-lg border border-[#06b6d4]" style="background-color:#1a4d4d;color:#06b6d4;">VAD</span>
            <span class="sm:px-2" style="color:#2a3a5c;">──────────▶</span>
            <div class="flex flex-col gap-1">
              <span class="px-3 py-1.5 rounded-lg border border-[#22c55e]" style="background-color:#1a4d2e;color:#22c55e;">Deepgram Nova-3 ☁ ~200ms</span>
              <span class="px-3 py-1.5 rounded-lg border border-[#8b5cf6]" style="background-color:#2d1b69;color:#8b5cf6;">whisper.cpp (local, offline)</span>
            </div>
            <span class="sm:px-2" style="color:#2a3a5c;">──transcript──▶</span>
            <div class="flex flex-col gap-1">
              <span class="px-3 py-1.5 rounded-lg border border-[#f59e0b]" style="background-color:#5c3d1a;color:#f59e0b;">LLM polish (optional)</span>
            </div>
            <span class="sm:px-2" style="color:#2a3a5c;">──inject──▶</span>
            <span class="px-3 py-1.5 rounded-lg border border-[#0d9488]" style="background-color:#134e4a;color:#0d9488;">Any App ✓</span>
          </div>

          <div class="mt-6 space-y-1 text-xs" style="color:#a0a0b0;">
            <p>▸ Audio never leaves your machine with local STT</p>
            <p>▸ With cloud STT, only audio is sent — transcript stays local</p>
            <p>▸ API keys stored in macOS Keychain &nbsp;·&nbsp; No telemetry &nbsp;·&nbsp; No analytics</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Swap in the real diagram image if it exists
  const img = new Image();
  img.src = '/flow-diagram.png';
  img.onload = () => {
    const el = document.getElementById('demo-content');
    if (el) {
      el.innerHTML = `<img src="/flow-diagram.png" alt="chamgei data flow diagram" class="w-full rounded-lg" />`;
    }
  };
</script>
