---
const faqs = [
  {
    q: "Does chamgei record audio without me knowing?",
    a: "No. Recording only starts when you hold ⌥Space (push-to-talk mode) or tap ⌥Space (toggle mode). The binary has no background audio capture — there is no daemon listening passively.",
  },
  {
    q: "What happens to my audio?",
    a: "With local STT (whisper.cpp), audio never leaves your machine. With cloud STT (Deepgram, Groq), audio is sent to that provider solely for transcription — the resulting text is never uploaded anywhere. Your LLM provider (if enabled) receives only the transcript, not the audio.",
  },
  {
    q: "Does it work with every app?",
    a: "Yes. chamgei injects text via keyboard simulation (CGEvent) or clipboard — the same methods macOS itself uses — so it works wherever your cursor is: browsers, native apps, terminals, Electron apps, etc. Accessibility permission is required for keyboard injection.",
  },
  {
    q: "Can I use it offline?",
    a: "Yes. Set stt_engine = \"local\" in ~/.config/chamgei/config.toml and chamgei will use whisper.cpp with Metal GPU acceleration. No internet required. Run chamgei setup to download the model (~75MB for tiny.en).",
  },
  {
    q: "Is it free? Will there be a paid tier?",
    a: "chamgei is MIT licensed and free forever. The only costs are from third-party API providers you choose to use (Deepgram, OpenAI, etc.) — and those are entirely optional since local STT + LLM are both supported.",
  },
];
---

<section class="max-w-3xl mx-auto px-6 py-20">
  <h2 class="text-3xl font-bold text-center mb-10" style="color:#ffffff;">Frequently asked questions</h2>

  <div class="space-y-3">
    {faqs.map(faq => (
      <details class="rounded-xl border border-[#2a3a5c] overflow-hidden group" style="background-color:#1f2b47;">
        <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer select-none font-medium list-none" style="color:#e0e0e0;">
          {faq.q}
          <svg class="w-4 h-4 shrink-0" style="color:#a0a0b0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <p class="px-5 pb-5 pt-1 text-sm leading-relaxed" style="color:#a0a0b0;" set:html={faq.a} />
      </details>
    ))}
  </div>
</section>
