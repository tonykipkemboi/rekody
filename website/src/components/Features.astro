---
const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M12 9l-3 3m0 0l3 3m-3-3h9"/></svg>`,
    title: '⌥Space Push-to-Talk',
    desc: 'Hold to record, release to transcribe. Injected directly at your cursor — no paste needed.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: 'Deepgram Nova-3',
    desc: '~200ms round-trip. Best-in-class accuracy with smart_format punctuation — no post-processing needed.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    title: 'Optional LLM Polish',
    desc: 'Route transcripts through Groq, GPT, Gemini, Ollama, or 7 more providers. Auto-disabled for Deepgram.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Works in Any App',
    desc: 'Notion, Slack, VS Code, Terminal — keyboard simulation injects text exactly where your cursor is.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
    title: 'Open Source · MIT',
    desc: 'No subscription, no lock-in, no black box. Fork it, audit it, extend it.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>`,
    title: 'Lightweight Rust Binary',
    desc: 'No Electron. No JVM. A single native binary ~5MB that starts in milliseconds.',
  },
];
---

<section class="max-w-5xl mx-auto px-6 py-20">
  <h2 class="text-3xl font-bold text-center mb-3" style="color:#ffffff;">Everything you need, nothing you don't</h2>
  <p class="text-center mb-12" style="color:#a0a0b0;">Built for developers who want to move faster without fighting their tools.</p>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {features.map(f => (
      <div class="rounded-xl border border-[#2a3a5c] p-6 transition-colors hover:border-[#0d9488]" style="background-color:#1f2b47;">
        <div class="mb-3" style="color:#0d9488;" set:html={f.icon} />
        <h3 class="font-semibold mb-1.5" style="color:#ffffff;">{f.title}</h3>
        <p class="text-sm leading-relaxed" style="color:#a0a0b0;">{f.desc}</p>
      </div>
    ))}
  </div>
</section>
