---
const features = [
  {
    emoji: "⌥",
    color: "#0ea5e9",
    bg: "rgba(14,165,233,0.1)",
    border: "rgba(14,165,233,0.2)",
    title: 'Push-to-talk hotkey',
    desc: 'Hold ⌥Space to record, release to transcribe. Injected at your cursor — no paste, no switching apps.',
  },
  {
    emoji: "⚡",
    color: "#06d6a0",
    bg: "rgba(6,214,160,0.1)",
    border: "rgba(6,214,160,0.2)",
    title: 'Deepgram Nova-3',
    desc: '~200ms round-trip. Auto-detects 100+ languages — English, Swahili, Arabic, Japanese, and more. smart_format punctuation included.',
  },
  {
    emoji: "🧠",
    color: "#a78bfa",
    bg: "rgba(167,139,250,0.1)",
    border: "rgba(167,139,250,0.2)",
    title: 'Optional LLM polish',
    desc: 'Route transcripts through Groq, GPT, Gemini, Ollama and 8 more. Auto-off when using Deepgram.',
  },
  {
    emoji: "✦",
    color: "#f59e0b",
    bg: "rgba(245,158,11,0.1)",
    border: "rgba(245,158,11,0.2)",
    title: 'Works in any app',
    desc: 'Notion, Slack, VS Code, Terminal — text injects exactly where your cursor is via keyboard simulation.',
  },
  {
    emoji: "◆",
    color: "#34d399",
    bg: "rgba(52,211,153,0.1)",
    border: "rgba(52,211,153,0.2)",
    title: 'Open source · MIT',
    desc: 'No subscription, no lock-in. Fork it, audit it, extend it. Your voice assistant, your rules.',
  },
  {
    emoji: "◈",
    color: "#fb7185",
    bg: "rgba(251,113,133,0.1)",
    border: "rgba(251,113,133,0.2)",
    title: 'Rust binary · 5MB',
    desc: 'No Electron. No JVM. A single native binary that starts in milliseconds and stays out of your way.',
  },
];
---

<section id="features" class="max-w-5xl mx-auto px-6 py-24">
  <div class="text-center mb-16">
    <h2 class="text-4xl sm:text-5xl font-bold mb-4 grad-text-white">Everything you need.</h2>
    <p class="text-lg max-w-lg mx-auto" style="color:#6b7fa0;">Built for anyone who wants to speak faster than they can type.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {features.map(f => (
      <div
        class="card-glow rounded-2xl p-6 transition-all"
        style={`background-color:#0c1528; border: 1px solid ${f.border};`}
      >
        <!-- Icon -->
        <div
          class="w-12 h-12 rounded-xl flex items-center justify-center text-xl font-bold mb-5"
          style={`background:${f.bg}; color:${f.color};`}
        >
          {f.emoji}
        </div>
        <h3 class="font-semibold text-base mb-2" style="color:#e8f0fa;">{f.title}</h3>
        <p class="text-sm leading-relaxed" style="color:#6b7fa0;">{f.desc}</p>
      </div>
    ))}
  </div>
</section>
