---
---

<section class="min-h-screen flex flex-col items-center justify-center text-center px-6 pt-20 pb-16">
  <!-- Animated badge -->
  <div class="mb-6 inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[#2a3a5c] text-xs font-mono hotkey-badge" style="background-color:#1f2b47;color:#0d9488;">
    <span class="w-2 h-2 rounded-full bg-[#0d9488] animate-pulse"></span>
    Hold ⌥Space to dictate
  </div>

  <!-- Headline -->
  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight mb-4 leading-none" style="color:#ffffff;">
    Speak.<br class="sm:hidden" />
    <span style="color:#0d9488;"> Release.</span><br class="sm:hidden" />
    Done.
  </h1>

  <!-- Subtext -->
  <p class="text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed" style="color:#a0a0b0;">
    Open-source macOS voice dictation. Hold&nbsp;⌥Space, speak, release —&nbsp;text appears at your cursor in <em>any</em>&nbsp;app.
    Powered by&nbsp;<strong style="color:#e0e0e0;">Deepgram&nbsp;Nova-3</strong> (~200ms latency).
  </p>

  <!-- CTAs -->
  <div class="flex flex-col sm:flex-row items-center gap-4 w-full max-w-xl mx-auto">
    <!-- Copy-on-click install command -->
    <button
      id="hero-install-btn"
      class="group flex-1 flex items-center gap-3 px-4 py-3 rounded-xl border border-[#2a3a5c] hover:border-[#0d9488] transition-all cursor-pointer text-left"
      style="background-color:#1f2b47;"
      aria-label="Copy install command"
    >
      <span style="color:#a0a0b0;" class="font-mono text-sm shrink-0">$</span>
      <code class="font-mono text-sm truncate flex-1" style="color:#0d9488;">
        curl -fsSL https://raw.githubusercontent.com/tonykipkemboi/chamgei/main/install.sh | bash
      </code>
      <!-- Copy icon -->
      <span id="hero-copy-icon" class="shrink-0 transition-colors" style="color:#a0a0b0;">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
      </span>
    </button>

    <!-- Download .dmg -->
    <a
      href="https://github.com/tonykipkemboi/chamgei/releases/latest"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 px-5 py-3 rounded-xl font-medium text-sm transition-colors hover:opacity-90"
      style="background-color:#0d9488;color:#ffffff;"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
      Download .dmg
    </a>
  </div>

  <!-- Copy feedback -->
  <p id="hero-copy-feedback" class="mt-3 text-sm transition-opacity duration-300 opacity-0" style="color:#0d9488;">
    Copied to clipboard!
  </p>

  <!-- Trust line -->
  <p class="mt-6 text-xs" style="color:#a0a0b0;">
    macOS 13+ &nbsp;·&nbsp; Apple Silicon &amp; Intel &nbsp;·&nbsp; MIT License &nbsp;·&nbsp; No telemetry
  </p>
</section>

<script>
  const btn = document.getElementById('hero-install-btn');
  const feedback = document.getElementById('hero-copy-feedback');
  const icon = document.getElementById('hero-copy-icon');
  const CMD = 'curl -fsSL https://raw.githubusercontent.com/tonykipkemboi/chamgei/main/install.sh | bash';

  const checkSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
  </svg>`;
  const copySvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
      d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
  </svg>`;

  btn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(CMD);
      if (icon) { icon.innerHTML = checkSvg; icon.style.color = '#0d9488'; }
      if (feedback) { feedback.classList.replace('opacity-0', 'opacity-100'); }
      setTimeout(() => {
        if (icon) { icon.innerHTML = copySvg; icon.style.color = '#a0a0b0'; }
        if (feedback) { feedback.classList.replace('opacity-100', 'opacity-0'); }
      }, 2000);
    } catch {
      window.getSelection()?.selectAllChildren(btn!);
    }
  });
</script>
