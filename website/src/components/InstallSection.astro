---
const tabs = [
  {
    id: 'curl',
    label: 'curl (recommended)',
    cmd: 'curl -fsSL https://raw.githubusercontent.com/tonykipkemboi/chamgei/main/install.sh | bash',
    note: 'Installs binary + downloads Whisper tiny model for offline fallback.',
  },
  {
    id: 'make',
    label: 'make install',
    cmd: 'git clone https://github.com/tonykipkemboi/chamgei.git\ncd chamgei\nmake install',
    note: 'Build from source. Requires Rust stable toolchain.',
  },
  {
    id: 'cargo',
    label: 'cargo install',
    cmd: 'cargo install --git https://github.com/tonykipkemboi/chamgei chamgei-core',
    note: 'For Rust users. Binary placed in ~/.cargo/bin.',
  },
];
---

<section class="max-w-5xl mx-auto px-6 py-20">
  <h2 class="text-3xl font-bold text-center mb-3" style="color:#ffffff;">Install</h2>
  <p class="text-center mb-10" style="color:#a0a0b0;">macOS 13 or later. Apple Silicon and Intel.</p>

  <!-- Tabs -->
  <div class="rounded-xl border border-[#2a3a5c] overflow-hidden" style="background-color:#131c30;">
    <!-- Tab bar -->
    <div class="flex border-b border-[#2a3a5c]" style="background-color:#1f2b47;">
      {tabs.map((t, i) => (
        <button
          data-tab={t.id}
          class={`px-4 py-3 text-sm font-medium border-b-2 transition-colors ${i === 0 ? 'border-[#0d9488]' : 'border-transparent'}`}
          style={i === 0 ? 'color:#0d9488;' : 'color:#a0a0b0;'}
        >
          {t.label}
        </button>
      ))}
    </div>

    <!-- Panels -->
    {tabs.map((t, i) => (
      <div data-panel={t.id} class={i !== 0 ? 'hidden' : ''}>
        <div class="flex items-start justify-between gap-4 px-5 py-5">
          <pre class="font-mono text-sm leading-relaxed overflow-x-auto flex-1" style="color:#0d9488;">{t.cmd}</pre>
          <button
            data-copy-btn={t.id}
            class="shrink-0 mt-0.5 transition-colors hover:text-white"
            style="color:#a0a0b0;"
            aria-label={`Copy ${t.label} command`}
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          </button>
        </div>
        <p class="px-5 pb-4 text-xs" style="color:#a0a0b0;">{t.note}</p>
      </div>
    ))}
  </div>

  <!-- Requirements -->
  <div class="mt-6 flex flex-wrap gap-3 justify-center">
    {['macOS 13+', 'Apple Silicon or Intel', 'Accessibility permission required', 'Microphone permission required'].map(req => (
      <span class="text-xs px-3 py-1 rounded-full border border-[#2a3a5c]" style="color:#a0a0b0;">{req}</span>
    ))}
  </div>
</section>

<script>
  // Tab switching
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab!;
      tabBtns.forEach(b => {
        b.style.color = '#a0a0b0';
        b.classList.replace('border-[#0d9488]', 'border-transparent');
      });
      panels.forEach(p => p.classList.add('hidden'));
      btn.style.color = '#0d9488';
      btn.classList.replace('border-transparent', 'border-[#0d9488]');
      document.querySelector<HTMLElement>(`[data-panel="${target}"]`)?.classList.remove('hidden');
    });
  });

  // Copy buttons
  const copyIconHtml = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>`;
  const checkIconHtml = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`;

  const cmds: Record<string, string> = {
    curl: 'curl -fsSL https://raw.githubusercontent.com/tonykipkemboi/chamgei/main/install.sh | bash',
    make: 'git clone https://github.com/tonykipkemboi/chamgei.git\ncd chamgei\nmake install',
    cargo: 'cargo install --git https://github.com/tonykipkemboi/chamgei chamgei-core',
  };

  document.querySelectorAll<HTMLButtonElement>('[data-copy-btn]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.copyBtn!;
      try {
        await navigator.clipboard.writeText(cmds[id] ?? '');
        btn.innerHTML = checkIconHtml;
        btn.style.color = '#0d9488';
        setTimeout(() => {
          btn.innerHTML = copyIconHtml;
          btn.style.color = '#a0a0b0';
        }, 2000);
      } catch { /* silent */ }
    });
  });
</script>
