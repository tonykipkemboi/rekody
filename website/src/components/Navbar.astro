---
import Mark from './Mark.astro';
import { version } from '../lib/version';

const links = [
  { label: 'How it works', href: '#how-it-works' },
  { label: 'Demo',         href: '#demo' },
  { label: 'Engines',      href: '#engines' },
  { label: 'Install',      href: '#install' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50" style="background:rgba(251,250,244,0.82); border-bottom:1px solid var(--color-hairline); backdrop-filter:saturate(1.2) blur(14px); -webkit-backdrop-filter:saturate(1.2) blur(14px);">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between gap-4">

    <!-- Wordmark -->
    <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="rekody — home">
      <Mark size={28} strokeColor="var(--color-ink)" />
      <span style="font-family:var(--font-serif); font-size:20px; font-weight:400; letter-spacing:-0.02em; color:var(--color-ink);">rekody</span>
    </a>

    <!-- Center links -->
    <div class="hidden md:flex items-center gap-1">
      {links.map(l => (
        <a
          href={l.href}
          class="nav-link px-3 py-1.5 rounded-full text-[13px] transition-colors"
          style="color:var(--color-ink-mute);"
        >{l.label}</a>
      ))}
    </div>

    <!-- Right actions -->
    <div class="hidden md:flex items-center gap-2 shrink-0">
      <a
        href="https://github.com/tonykipkemboi/rekody"
        target="_blank"
        rel="noopener noreferrer"
        class="pill pill-ghost"
        aria-label="Star on GitHub"
      >
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <span>Star</span>
      </a>

      <a href="#install" class="pill pill-dark">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download
      </a>
    </div>

    <!-- Mobile right -->
    <div class="flex md:hidden items-center gap-2 shrink-0">
      <a href="#install" class="pill pill-dark" style="font-size:12px;">Download</a>
      <button
        id="nav-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="flex items-center justify-center w-9 h-9 rounded-full"
        style="color:var(--color-ink); border:1px solid var(--color-hairline);"
      >
        <svg id="hamburger-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div
    id="nav-drawer"
    class="hidden md:hidden"
    style="border-top:1px solid var(--color-hairline); background:#FBFAF4;"
  >
    <div class="max-w-6xl mx-auto px-6 py-3 flex flex-col gap-1">
      {links.map(l => (
        <a
          href={l.href}
          class="drawer-link px-3 py-3 rounded-lg text-sm font-medium transition-colors"
          style="color:var(--color-ink-soft);"
        >{l.label}</a>
      ))}
      <div class="my-1 hairline"></div>
      <a
        href="https://github.com/tonykipkemboi/rekody"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-3 py-3 rounded-lg text-sm"
        style="color:var(--color-ink-soft);"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        GitHub
        <span class="ml-auto font-mono text-[10px] px-1.5 py-0.5 rounded" style="background:var(--color-teal-soft); color:var(--color-teal);">v{version}</span>
      </a>
    </div>
  </div>
</nav>

<style>
  .nav-link:hover { color: var(--color-ink); background: rgba(15,23,23,0.04); }
  .drawer-link:hover { color: var(--color-ink); background: rgba(15,23,23,0.04); }
</style>

<script>
  const toggle    = document.getElementById('nav-toggle');
  const drawer    = document.getElementById('nav-drawer');
  const hamIcon   = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  function openDrawer() {
    drawer?.classList.remove('hidden');
    hamIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
  }
  function closeDrawer() {
    drawer?.classList.add('hidden');
    hamIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    drawer?.classList.contains('hidden') ? openDrawer() : closeDrawer();
  });
  drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawer));
  document.addEventListener('click', (e) => {
    const nav = document.getElementById('navbar');
    if (nav && !nav.contains(e.target as Node)) closeDrawer();
  });
</script>
