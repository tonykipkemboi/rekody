---
---

<section class="max-w-5xl mx-auto px-6 py-16 text-center">
  <div class="inline-flex flex-col sm:flex-row items-center gap-5 rounded-2xl border border-[#1e2e4a] px-8 py-6 glass">
    <!-- Stars (only shown if > 0) -->
    <div class="flex items-center gap-2">
      <a
        href="https://github.com/tonykipkemboi/chamgei"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-2 rounded-xl border border-[#1e2e4a] text-sm font-medium hover:border-[#0ea5e9] transition-colors"
        style="background:#0c1528; color:#e8f0fa;"
      >
        <svg class="w-4 h-4" style="color:#f59e0b;" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <span id="star-count">Star on GitHub</span>
      </a>
    </div>

    <div class="hidden sm:block w-px h-8 bg-[#1e2e4a]"></div>

    <!-- Open source -->
    <div class="flex items-center gap-2 text-sm" style="color:#e8f0fa;">
      <svg class="w-4 h-4" style="color:#34d399;" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
      MIT Licensed &amp; Open Source
    </div>

    <div class="hidden sm:block w-px h-8 bg-[#1e2e4a]"></div>

    <!-- Version -->
    <div class="flex items-center gap-2">
      <span class="font-mono text-xs px-3 py-1.5 rounded-lg" style="background:rgba(14,165,233,0.1);color:#0ea5e9;border:1px solid rgba(14,165,233,0.2);">v0.3.0</span>
      <a href="https://github.com/tonykipkemboi/chamgei/releases" target="_blank" rel="noopener noreferrer"
        class="text-sm hover:text-white transition-colors" style="color:#6b7fa0;">
        Release notes →
      </a>
    </div>
  </div>
</section>

<script>
  (async () => {
    try {
      const controller = new AbortController();
      const timer = setTimeout(() => controller.abort(), 5000);
      const res = await fetch('https://api.github.com/repos/tonykipkemboi/chamgei', {
        signal: controller.signal,
      });
      clearTimeout(timer);
      if (!res.ok) return;
      const data = await res.json() as { stargazers_count?: number };
      const count = data.stargazers_count;
      if (typeof count === 'number' && count >= 0) {
        const el = document.getElementById('star-count');
        if (el) el.textContent = `${count.toLocaleString()} stars`;
      }
    } catch { /* silent — network unavailable or timed out */ }
  })();
</script>
