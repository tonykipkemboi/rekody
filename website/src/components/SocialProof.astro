---
---

<section class="max-w-5xl mx-auto px-6 py-16 text-center">
  <div class="inline-flex flex-col sm:flex-row items-center gap-6 rounded-2xl border border-[#2a3a5c] px-8 py-6" style="background-color:#1f2b47;">
    <!-- Stars -->
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5" style="color:#f59e0b;" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      <span id="star-count" class="text-2xl font-bold" style="color:#ffffff;">★ Star on GitHub</span>
    </div>

    <div class="hidden sm:block w-px h-8 bg-[#2a3a5c]"></div>

    <!-- Open source badge -->
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5" style="color:#22c55e;" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
      <span class="font-medium" style="color:#e0e0e0;">MIT Licensed &amp; Open Source</span>
    </div>

    <div class="hidden sm:block w-px h-8 bg-[#2a3a5c]"></div>

    <!-- Version -->
    <div class="flex items-center gap-2">
      <span class="font-mono text-sm px-3 py-1 rounded-full" style="background-color:#131c30;color:#0d9488;">v0.3.0</span>
      <a
        href="https://github.com/tonykipkemboi/chamgei/releases"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm hover:text-white transition-colors"
        style="color:#a0a0b0;"
      >
        Release notes →
      </a>
    </div>
  </div>
</section>

<script>
  // Gracefully fetch live star count — fails silently for private repos
  (async () => {
    try {
      const res = await fetch('https://api.github.com/repos/tonykipkemboi/chamgei');
      if (!res.ok) return;
      const data = await res.json() as { stargazers_count?: number };
      const count = data.stargazers_count;
      if (typeof count === 'number') {
        const el = document.getElementById('star-count');
        if (el) el.textContent = `${count.toLocaleString()} stars`;
      }
    } catch { /* silent */ }
  })();
</script>
