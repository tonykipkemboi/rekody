---
const engines = [
  {
    name: 'Deepgram',
    model: 'Nova-3',
    quality: 5,
    latency: '~200ms',
    offline: false,
    notes: 'smart_format, punctuation, best accuracy. Recommended.',
    recommended: true,
  },
  {
    name: 'Groq',
    model: 'Whisper Large v3',
    quality: 4,
    latency: '~300ms',
    offline: false,
    notes: 'Fast cloud inference. Great fallback.',
    recommended: false,
  },
  {
    name: 'Local',
    model: 'whisper.cpp',
    quality: 3,
    latency: 'varies',
    offline: true,
    notes: 'Runs on-device with Metal GPU acceleration. Zero cloud.',
    recommended: false,
  },
  {
    name: 'Cohere',
    model: 'Custom server',
    quality: 4,
    latency: 'varies',
    offline: true,
    notes: 'Self-hosted endpoint. Configurable port.',
    recommended: false,
  },
];
---

<section class="max-w-5xl mx-auto px-6 py-20">
  <h2 class="text-3xl font-bold text-center mb-3" style="color:#ffffff;">Choose your STT engine</h2>
  <p class="text-center mb-10" style="color:#a0a0b0;">Set <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background-color:#1f2b47;color:#0d9488;">stt_engine</code> in your config. Switch any time.</p>

  <div class="overflow-x-auto rounded-xl border border-[#2a3a5c]">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-[#2a3a5c] text-xs uppercase tracking-wider" style="background-color:#1f2b47;color:#a0a0b0;">
          <th class="text-left px-5 py-3">Engine</th>
          <th class="text-left px-5 py-3">Model</th>
          <th class="text-left px-5 py-3">Quality</th>
          <th class="text-left px-5 py-3">Latency</th>
          <th class="text-left px-5 py-3">Offline</th>
          <th class="text-left px-5 py-3">Notes</th>
        </tr>
      </thead>
      <tbody>
        {engines.map(e => (
          <tr
            class={`border-b border-[#2a3a5c] last:border-0 transition-colors hover:bg-[#1f2b47] ${e.recommended ? 'border-l-2 border-l-[#0d9488]' : ''}`}
            style="background-color:#131c30;"
          >
            <td class="px-5 py-4 font-semibold" style={e.recommended ? 'color:#0d9488;' : 'color:#e0e0e0;'}>
              {e.name}
              {e.recommended && <span class="ml-2 text-xs px-1.5 py-0.5 rounded-full font-mono" style="background-color:#134e4a;color:#0d9488;">recommended</span>}
            </td>
            <td class="px-5 py-4 font-mono text-xs" style="color:#a0a0b0;">{e.model}</td>
            <td class="px-5 py-4">
              <span style="color:#f59e0b;">{'★'.repeat(e.quality)}</span>
              <span style="color:#2a3a5c;">{'★'.repeat(5 - e.quality)}</span>
            </td>
            <td class="px-5 py-4 font-mono text-xs" style="color:#e0e0e0;">{e.latency}</td>
            <td class="px-5 py-4">
              {e.offline
                ? <span class="px-2 py-0.5 rounded-full text-xs" style="background-color:#1a4d2e;color:#22c55e;">Yes</span>
                : <span class="px-2 py-0.5 rounded-full text-xs" style="background-color:#1f2b47;color:#a0a0b0;">No</span>
              }
            </td>
            <td class="px-5 py-4 text-xs" style="color:#a0a0b0;">{e.notes}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
