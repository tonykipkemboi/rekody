---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  faqSchema?: { q: string; a: string }[];
}

const {
  title = 'chamgei — Voice Dictation for Everyone',
  description = 'Open-source macOS voice dictation. Hold ⌥Space, speak, release. Text injected at your cursor in any app. Push-to-talk, 100+ languages, powered by Deepgram Nova-3 (~200ms).',
  ogImage = '/og-image.png',
  faqSchema,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://chamgei.com');
const ogImageUrl = new URL(ogImage, Astro.site ?? 'https://chamgei.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Tony Kipkemboi" />
    <meta name="theme-color" content="#0d9488" />

    <!-- Robots -->
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="chamgei" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="chamgei — Voice dictation for everyone. Speak. Release. Done." />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@tonykipkemboi" />
    <meta name="twitter:creator" content="@tonykipkemboi" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="chamgei — Voice dictation for everyone. Speak. Release. Done." />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/icon.png" sizes="128x128" />
    <link rel="apple-touch-icon" href="/icon.png" />

    <!-- JSON-LD: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "chamgei",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "macOS",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "url": "https://chamgei.com",
      "description": description,
      "license": "https://opensource.org/licenses/MIT",
      "author": {
        "@type": "Person",
        "name": "Tony Kipkemboi",
        "url": "https://github.com/tonykipkemboi",
      },
    })} />

    <!-- JSON-LD: FAQPage -->
    {faqSchema && faqSchema.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqSchema.map(({ q, a }) => ({
          "@type": "Question",
          "name": q,
          "acceptedAnswer": { "@type": "Answer", "text": a },
        })),
      })} />
    )}
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>
